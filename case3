<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Case 03 — Ownly by Rapido · Anjana</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap');

  :root{
    --bg:        #EDE8DF;
    --bg-deep:   #E4DDD2;
    --card:      #F5F0E8;
    --line:      #D4C9B8;
    --ink:       #2A1F14;
    --ink-soft:  #5A4A38;
    --ink-mute:  #9A8C7C;
    --terra:     #C4592F;
    --terra-dim: rgba(196,89,47,0.12);
    --hot:       #E8197A;
    --hot-dim:   rgba(232,25,122,0.10);
    --warm:      #E8A050;
    --warm-dim:  rgba(232,160,80,0.15);
    --green:     #4A7C59;
    --green-dim: rgba(74,124,89,0.12);
  }

  *{ box-sizing:border-box; margin:0; padding:0; }
  html{ scroll-behavior:smooth; }
  body{
    background:var(--bg);
    background-image:radial-gradient(circle at 1px 1px,rgba(42,31,20,0.04) 1px,transparent 0);
    background-size:24px 24px;
    color:var(--ink);
    font-family:'Inter',sans-serif;
    line-height:1.65;
    -webkit-font-smoothing:antialiased;
  }
  .mono{ font-family:'JetBrains Mono',monospace; }
  a{ color:inherit; text-decoration:none; }
  :focus-visible{ outline:2px solid var(--hot); outline-offset:2px; }

  /* ===== Header ===== */
  header{
    display:flex; justify-content:space-between; align-items:center;
    padding:26px clamp(20px,5vw,64px) 16px;
    border-bottom:1px solid var(--line);
    position:sticky; top:0; background:rgba(237,232,223,0.94);
    backdrop-filter:blur(8px); z-index:50;
  }
  .logo{ font-family:'Spectral',serif; font-weight:700; font-size:1.12rem; color:var(--ink); }
  .logo .dot{ color:var(--terra); }
  nav.headlinks{ display:flex; gap:26px; align-items:center; }
  nav.headlinks a{ font-size:0.82rem; font-weight:600; color:var(--ink-soft); border-bottom:1px solid transparent; transition:border-color .2s,color .2s; padding-bottom:2px; }
  nav.headlinks a:hover{ color:var(--terra); border-color:var(--terra); }
  .back-link{ display:flex; align-items:center; gap:6px; }
  .back-link svg{ width:13px; height:13px; }

  /* ===== OWNLY HERO BANNER ===== */
  .ownly-hero{
    background: linear-gradient(135deg, #E8197A 0%, #D4006A 40%, #B5005A 100%);
    padding:clamp(48px,8vw,88px) clamp(20px,5vw,64px) clamp(40px,6vw,72px);
    text-align:center;
    position:relative;
    overflow:hidden;
  }
  .ownly-hero::before{
    content:"";
    position:absolute; inset:0;
    background:radial-gradient(ellipse at 50% 0%,rgba(255,255,255,0.12),transparent 60%);
    pointer-events:none;
  }
  /* Subtle texture dots like the screenshot */
  .ownly-hero::after{
    content:"";
    position:absolute; inset:0;
    background-image:radial-gradient(circle at 1px 1px,rgba(255,255,255,0.06) 1px,transparent 0);
    background-size:28px 28px;
    pointer-events:none;
  }
  .hero-eyebrow{
    font-family:'JetBrains Mono',monospace; font-size:0.72rem; font-weight:600;
    letter-spacing:0.25em; text-transform:uppercase; color:rgba(255,255,255,0.7);
    margin-bottom:16px; position:relative; z-index:1;
  }
  .hero-title{
    font-family:'Inter',sans-serif; font-weight:900;
    font-size:clamp(3rem,9vw,7rem);
    line-height:0.95; letter-spacing:-0.04em;
    color:#fff;
    margin-bottom:16px;
    position:relative; z-index:1;
  }
  .hero-sub{
    font-size:clamp(1rem,2.2vw,1.35rem); color:rgba(255,255,255,0.8);
    max-width:56ch; margin:0 auto 32px;
    position:relative; z-index:1; line-height:1.6;
  }
  .hero-tags{ display:flex; gap:8px; justify-content:center; flex-wrap:wrap; position:relative; z-index:1; }
  .hero-tag{
    font-family:'JetBrains Mono',monospace; font-size:0.68rem;
    padding:5px 12px; border:1px solid rgba(255,255,255,0.35); border-radius:20px;
    color:rgba(255,255,255,0.85); background:rgba(255,255,255,0.08);
  }
  .hero-case-badge{
    position:absolute; top:clamp(16px,3vw,28px); right:clamp(16px,3vw,28px);
    font-family:'JetBrains Mono',monospace; font-size:0.68rem; font-weight:700;
    color:rgba(255,255,255,0.5); letter-spacing:0.1em; z-index:2;
    text-transform:uppercase;
  }
  /* Video embed card */
  .hero-video-card{
    max-width:680px; margin:36px auto 0;
    background:#111; border-radius:14px; overflow:hidden;
    position:relative; z-index:1;
    box-shadow:0 24px 64px rgba(0,0,0,0.45);
  }
  .video-top{ background:#1A1A1A; padding:10px 16px; display:flex; align-items:center; gap:10px; }
  .video-logo{
    width:28px; height:28px; border-radius:50%; background:var(--hot);
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
    font-size:10px; font-weight:900; color:#fff; font-family:'Inter',sans-serif;
  }
  .video-meta{ text-align:left; }
  .video-title{ font-size:0.78rem; font-weight:700; color:#fff; line-height:1.3; }
  .video-channel{ font-size:0.66rem; color:#888; }
  .video-thumb{
    width:100%; aspect-ratio:16/9; background:linear-gradient(135deg,#1C1C1C,#2A1010);
    display:flex; align-items:center; justify-content:center; position:relative;
    overflow:hidden;
  }
  .video-thumb-text{
    position:absolute; bottom:16px; left:20px; right:20px;
    font-family:'Inter',sans-serif; font-size:clamp(1.1rem,3vw,1.8rem);
    font-weight:900; color:rgba(255,255,255,0.15); letter-spacing:-0.02em;
    text-align:left; line-height:1.1;
  }
  /* Big play button */
  .play-btn{
    width:64px; height:46px; background:#FF0000; border-radius:12px;
    display:flex; align-items:center; justify-content:center; position:relative; z-index:1;
  }
  .play-btn::after{
    content:""; border-left:20px solid #fff; border-top:12px solid transparent;
    border-bottom:12px solid transparent; margin-left:4px;
  }

  /* ===== Scoreboard ===== */
  .scoreboard{
    display:grid; grid-template-columns:repeat(4,1fr);
    border:1px solid var(--line); border-radius:6px; overflow:hidden;
    margin:44px 0 0; max-width:1100px;
  }
  .score-cell{ padding:22px 20px 18px; border-right:1px solid var(--line); position:relative; }
  .score-cell:last-child{ border-right:none; }
  .score-cell::before{ content:""; position:absolute; top:0; left:0; right:0; height:3px; }
  .score-cell.hot::before{ background:var(--hot); }
  .score-cell.terra::before{ background:var(--terra); }
  .score-cell.warm::before{ background:var(--warm); }
  .score-cell.green::before{ background:var(--green); }
  .score-val{ font-family:'JetBrains Mono',monospace; font-weight:700; font-size:clamp(1.5rem,3vw,2.2rem); letter-spacing:-0.02em; line-height:1; display:block; }
  .score-cell.hot .score-val{ color:var(--hot); }
  .score-cell.terra .score-val{ color:var(--terra); }
  .score-cell.warm .score-val{ color:var(--warm); }
  .score-cell.green .score-val{ color:var(--green); }
  .score-label{ font-size:0.74rem; color:var(--ink-soft); margin-top:7px; display:block; line-height:1.4; }
  .score-sub{ font-family:'JetBrains Mono',monospace; font-size:0.6rem; color:var(--ink-mute); margin-top:4px; }

  /* ===== Layout ===== */
  .case-body{ display:grid; grid-template-columns:220px 1fr; gap:48px; max-width:1100px; margin:0 auto; padding:44px clamp(20px,5vw,64px) 100px; align-items:start; }

  .side-nav{ position:sticky; top:88px; display:flex; flex-direction:column; gap:2px; border-left:2px solid var(--line); }
  .side-nav button{ all:unset; cursor:pointer; font-family:'Inter',sans-serif; font-size:0.82rem; font-weight:600; color:var(--ink-mute); padding:9px 0 9px 18px; border-left:2px solid transparent; margin-left:-2px; transition:color .18s,border-color .18s; display:flex; align-items:center; }
  .side-nav button:hover{ color:var(--ink); }
  .side-nav button.active{ color:var(--hot); border-left:2px solid var(--hot); }
  .side-nav .step-no{ font-family:'JetBrains Mono',monospace; font-size:0.68rem; font-weight:700; margin-right:8px; color:#BBB0A0; background:rgba(42,31,20,0.08); padding:1px 5px; border-radius:2px; }
  .side-nav button.active .step-no{ color:#fff; background:var(--hot); }

  /* ===== Panels ===== */
  .panels{ min-width:0; }
  .panel{ display:none; animation:fadeIn .22s ease; }
  .panel.active{ display:block; }
  @keyframes fadeIn{ from{opacity:0;transform:translateY(5px);} to{opacity:1;transform:translateY(0);} }

  .panel-eyebrow{ font-family:'JetBrains Mono',monospace; font-size:0.7rem; text-transform:uppercase; letter-spacing:0.1em; color:var(--hot); display:flex; align-items:center; gap:10px; margin-bottom:14px; }
  .panel-eyebrow::before{ content:""; width:16px; height:1px; background:var(--hot); }
  .panel h2{ font-family:'Spectral',serif; font-weight:700; font-size:1.65rem; margin-bottom:18px; letter-spacing:-0.01em; color:var(--ink); line-height:1.15; }
  .panel p{ margin-bottom:14px; color:var(--ink-soft); font-size:0.95rem; line-height:1.78; }
  .panel strong{ color:var(--ink); font-weight:700; }
  .panel em{ color:var(--hot); font-style:normal; font-weight:600; }

  /* Callouts */
  .callout{ background:var(--hot-dim); border-left:3px solid var(--hot); padding:16px 18px; border-radius:4px; font-size:0.9rem; margin:20px 0; color:var(--ink); line-height:1.72; }
  .callout b{ font-family:'JetBrains Mono',monospace; font-size:0.72rem; text-transform:uppercase; display:block; margin-bottom:8px; letter-spacing:0.06em; color:var(--hot); font-weight:700; }
  .callout.terra{ background:var(--terra-dim); border-left-color:var(--terra); }
  .callout.terra b{ color:var(--terra); }
  .callout.warm{ background:var(--warm-dim); border-left-color:var(--warm); }
  .callout.warm b{ color:var(--warm); }
  .callout.green{ background:var(--green-dim); border-left-color:var(--green); }
  .callout.green b{ color:var(--green); }
  .callout.ink{ background:rgba(42,31,20,0.07); border-left-color:var(--ink); }
  .callout.ink b{ color:var(--ink); }

  /* Finding cards */
  .finding-grid{ display:grid; grid-template-columns:repeat(auto-fit,minmax(210px,1fr)); gap:14px; margin:22px 0; }
  .finding-card{ background:var(--card); border:1px solid var(--line); border-radius:6px; padding:18px 16px; border-top:3px solid; }
  .finding-card.good{ border-top-color:var(--green); }
  .finding-card.bad{ border-top-color:var(--terra); }
  .finding-card.mid{ border-top-color:var(--warm); }
  .finding-card.hot{ border-top-color:var(--hot); }
  .finding-title{ font-weight:700; font-size:0.88rem; color:var(--ink); margin-bottom:6px; }
  .finding-body{ font-size:0.8rem; color:var(--ink-soft); line-height:1.65; }

  /* Stat grid */
  .stat-grid{ display:grid; grid-template-columns:repeat(auto-fit,minmax(170px,1fr)); gap:14px; margin:22px 0; }
  .stat-card{ background:var(--card); border:1px solid var(--line); border-radius:6px; padding:18px 16px; }
  .stat-num{ font-family:'Spectral',serif; font-weight:700; font-size:2rem; color:var(--terra); line-height:1; }
  .stat-label{ font-size:0.76rem; color:var(--ink-soft); margin-top:6px; line-height:1.45; }
  .stat-src{ font-family:'JetBrains Mono',monospace; font-size:0.6rem; color:var(--ink-mute); margin-top:8px; }

  /* Finance table */
  .fin-table{ width:100%; border-collapse:collapse; margin:20px 0; font-size:0.86rem; }
  .fin-table th{ font-family:'JetBrains Mono',monospace; font-size:0.68rem; text-transform:uppercase; letter-spacing:0.05em; color:var(--ink-mute); text-align:left; padding:8px 12px; border-bottom:2px solid var(--ink); }
  .fin-table td{ padding:10px 12px; border-bottom:1px solid var(--line); color:var(--ink-soft); vertical-align:top; }
  .fin-table td:first-child{ font-weight:700; color:var(--ink); }
  .fin-table tr.highlight td{ background:var(--terra-dim); color:var(--ink); }
  .fin-table tr.highlight td:first-child{ color:var(--terra); }
  .fin-table tr.good td{ background:var(--green-dim); }
  .fin-table tr.good td:first-child{ color:var(--green); }
  .fin-table tr.hot td{ background:var(--hot-dim); }
  .fin-table tr.hot td:first-child{ color:var(--hot); }

  /* Bar chart */
  .chart-wrap{ background:var(--card); border:1px solid var(--line); border-radius:8px; padding:22px 20px; margin:22px 0; }
  .chart-title{ font-family:'JetBrains Mono',monospace; font-size:0.72rem; text-transform:uppercase; letter-spacing:0.06em; color:var(--ink-mute); margin-bottom:16px; }
  .bar-row{ display:flex; align-items:center; gap:12px; margin-bottom:11px; }
  .bar-label{ width:160px; font-size:0.78rem; color:var(--ink-soft); flex-shrink:0; }
  .bar-track{ flex-grow:1; background:var(--bg-deep); border-radius:3px; height:20px; overflow:hidden; }
  .bar-fill{ height:100%; background:var(--hot); border-radius:3px; display:flex; align-items:center; justify-content:flex-end; padding-right:8px; }
  .bar-fill.terra{ background:var(--terra); }
  .bar-fill.warm{ background:var(--warm); }
  .bar-fill.green{ background:var(--green); }
  .bar-fill.ink{ background:var(--ink); }
  .bar-fill span{ font-family:'JetBrains Mono',monospace; font-size:0.66rem; color:#fff; font-weight:700; }

  /* Journey steps */
  .journey{ display:flex; flex-direction:column; margin:24px 0; }
  .j-step{ display:grid; grid-template-columns:36px 1fr; gap:16px; padding-bottom:24px; position:relative; }
  .j-step:not(:last-child)::before{ content:""; position:absolute; left:17px; top:34px; bottom:0; width:1px; background:var(--line); }
  .j-num{ width:34px; height:34px; border-radius:4px; background:var(--hot); color:#fff; display:flex; align-items:center; justify-content:center; font-family:'JetBrains Mono',monospace; font-size:0.8rem; font-weight:700; flex-shrink:0; z-index:1; }
  .j-num.terra{ background:var(--terra); }
  .j-num.warm{ background:var(--warm); color:var(--ink); }
  .j-num.green{ background:var(--green); }
  .j-num.ink{ background:var(--ink); }
  .j-content h3{ font-family:'Spectral',serif; font-weight:700; font-size:1.02rem; margin-bottom:5px; color:var(--ink); }
  .j-content p{ font-size:0.86rem; color:var(--ink-soft); margin-bottom:0; }

  /* Unit econ comparison */
  .compare-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin:22px 0; }
  .compare-card{ background:var(--card); border:1px solid var(--line); border-radius:6px; padding:18px 16px; }
  .compare-head{ font-family:'JetBrains Mono',monospace; font-size:0.7rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:12px; padding-bottom:8px; border-bottom:2px solid; }
  .compare-card.terra .compare-head{ color:var(--terra); border-color:var(--terra); }
  .compare-card.hot .compare-head{ color:var(--hot); border-color:var(--hot); }
  .compare-card.green .compare-head{ color:var(--green); border-color:var(--green); }
  .compare-row{ display:flex; justify-content:space-between; align-items:baseline; margin-bottom:8px; font-size:0.82rem; }
  .compare-row .ck{ color:var(--ink-mute); }
  .compare-row .cv{ font-weight:700; color:var(--ink); }
  .compare-row .cv.pos{ color:var(--green); }
  .compare-row .cv.neg{ color:var(--terra); }

  /* Rec blocks */
  .rec-block{ background:var(--card); border:1px solid var(--line); border-radius:6px; padding:24px 22px; margin:22px 0; position:relative; }
  .rec-num{ position:absolute; top:-13px; left:18px; font-family:'JetBrains Mono',monospace; font-size:0.68rem; font-weight:700; background:var(--hot); color:#fff; padding:4px 10px; border-radius:3px; text-transform:uppercase; letter-spacing:0.06em; }
  .rec-title{ font-family:'Spectral',serif; font-weight:700; font-size:1.1rem; color:var(--ink); margin-bottom:8px; margin-top:4px; }
  .rec-body{ font-size:0.88rem; color:var(--ink-soft); line-height:1.75; }
  .rec-body strong{ color:var(--ink); }
  .rec-metric{ margin-top:14px; padding-top:14px; border-top:1px solid var(--line); font-family:'JetBrains Mono',monospace; font-size:0.7rem; color:var(--ink-mute); }
  .rec-metric span{ color:var(--hot); font-weight:700; }

  /* KANO table */
  .kano-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin:22px 0; }
  .kano-card{ background:var(--card); border:1px solid var(--line); border-radius:6px; padding:16px; }
  .kano-head{ font-family:'JetBrains Mono',monospace; font-size:0.68rem; text-transform:uppercase; letter-spacing:0.06em; font-weight:700; margin-bottom:10px; padding-bottom:8px; border-bottom:1.5px solid; }
  .kano-card.must .kano-head{ color:var(--terra); border-color:var(--terra); }
  .kano-card.perf .kano-head{ color:var(--warm); border-color:var(--warm); }
  .kano-card.delight .kano-head{ color:var(--green); border-color:var(--green); }
  .kano-item{ font-size:0.8rem; color:var(--ink-soft); margin-bottom:7px; display:flex; gap:7px; align-items:flex-start; line-height:1.5; }
  .kano-item::before{ content:"·"; color:var(--ink-mute); flex-shrink:0; margin-top:1px; }

  .sources-block{ margin-top:28px; padding-top:16px; border-top:1px dashed var(--line); font-size:0.74rem; color:var(--ink-mute); font-family:'JetBrains Mono',monospace; line-height:1.8; }
  .sources-block li{ list-style:none; margin-bottom:2px; }

  .case-foot-nav{ display:flex; justify-content:space-between; align-items:center; max-width:1100px; margin:0 auto; padding:0 clamp(20px,5vw,64px) 60px; border-top:1px solid var(--line); padding-top:26px; }
  .case-foot-nav a{ font-size:0.82rem; font-weight:600; color:var(--ink-soft); display:flex; align-items:center; gap:6px; }
  .case-foot-nav a:hover{ color:var(--hot); }
  footer{ border-top:1px solid var(--line); padding:22px clamp(20px,5vw,64px) 36px; display:flex; justify-content:space-between; font-size:0.76rem; color:var(--ink-mute); flex-wrap:wrap; gap:10px; }

  @media(max-width:860px){
    .case-body{ grid-template-columns:1fr; }
    .scoreboard{ grid-template-columns:1fr 1fr; }
    .scoreboard .score-cell:nth-child(2){ border-right:none; }
    .scoreboard .score-cell:nth-child(3){ border-top:1px solid var(--line); }
    .scoreboard .score-cell:nth-child(4){ border-top:1px solid var(--line); border-right:none; }
    .compare-grid,.kano-grid{ grid-template-columns:1fr; }
    .side-nav{ position:static; flex-direction:row; flex-wrap:wrap; border-left:none; border-bottom:1px solid var(--line); padding-bottom:14px; gap:8px; }
    .side-nav button{ border-left:none; border:1px solid var(--line); border-radius:20px; padding:6px 13px; margin-left:0; font-size:0.74rem; }
    .side-nav button.active{ border-color:var(--hot); background:var(--hot-dim); }
  }
  @media(max-width:560px){ header{ flex-direction:column; align-items:flex-start; gap:12px; } }
  @media(prefers-reduced-motion:reduce){ *{ scroll-behavior:auto!important; transition:none!important; animation:none!important; } }
</style>
</head>
